<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Archana Collection - Cost To Cost Sale</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:Arial, Helvetica, sans-serif;
    background:#f5f5f5;
}

.banner{
    width:100%;
    min-height:100vh;
    background:url('images/archana-banner.png') center center no-repeat;
    background-size:contain;
    background-color:#ffffff;
    position:relative;
}

.overlay{
    position:absolute;
    bottom:40px;
    left:50%;
    transform:translateX(-50%);
    text-align:center;
}

.btn{
    background:#ffcc00;
    color:#000;
    text-decoration:none;
    padding:15px 35px;
    border-radius:8px;
    font-size:20px;
    font-weight:bold;
    box-shadow:0 4px 10px rgba(0,0,0,.3);
    transition:.3s;
}

.btn:hover{
    background:#ffd633;
    transform:translateY(-2px);
}

@media(max-width:768px){
    .banner{
        min-height:60vh;
        background-size:contain;
    }

    .btn{
        font-size:16px;
        padding:12px 24px;
    }
}
</style>
</head>
<body>

<div class="banner">
    <div class="overlay">
        <a href="#" class="btn">Shop Now</a>
    </div>
</div>

</body>
</html>
